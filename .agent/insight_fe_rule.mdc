## Page Patterns

### Server page (app/[locale]/.../page.js)
```js
import { setRequestLocale } from 'next-intl/server';

export const revalidate = 300; // ISR interval in seconds

export async function generateMetadata({ params }) {
  const { locale, name } = await params;
  setRequestLocale(locale);
  // Return locale-aware metadata
  return locale === 'vi'
    ? { title: `Tiêu đề: ${name}`, description: `Mô tả cho ${name}` }
    : { title: `Title: ${name}`, description: `Description for ${name}` };
}

export default async function Page({ params }) {
  const { locale, ...rest } = await params;
  setRequestLocale(locale);
  // Optional: prefetch data for SSR
  let initialData = null;
  try { initialData = await fetchData(); } catch { /* fallback to client */ }
  return <ClientComponent initialData={initialData} {...rest} />;
}
```

### Client page component
```js
'use client';
export default function SomeClient({ initialData, name }) {
  const { posts, isLoading, isError, setSize, isReachingEnd } = useInfiniteXxx(name);
  return (
    <HomeLayout sidebar={<PersonalBlogSidebar />}>
      <FeatureComponent posts={posts} isLoading={isLoading} ... />
    </HomeLayout>
  );
}
```

### Metadata
- ALL pages MUST have `generateMetadata` (or static `metadata` export)
- ALL metadata MUST be locale-aware (`locale === 'vi'` branch)
- Post pages MUST include OpenGraph tags

